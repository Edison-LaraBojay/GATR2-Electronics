# ---------------------------------------------------------------------------
# Editors and OS
# ---------------------------------------------------------------------------
**/.vscode/.browse.c_cpp.db*
**/.vscode/c_cpp_properties.json
**/.vscode/launch.json
**/.vscode/ipch
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# PlatformIO
# ---------------------------------------------------------------------------
.pio

# ---------------------------------------------------------------------------
# KiCad
#
# Committed: .kicad_pro, .kicad_sch, .kicad_pcb, .kicad_sym, .kicad_mod,
# .pretty/, .kicad_dru, fp-lib-table, sym-lib-table.
# Everything below is regenerated, per user, or large.
# ---------------------------------------------------------------------------

# Auto backup archives. KiCad zips the whole project on every save and these
# grow without bound.
*-backups/

# Per user window and view state, not shared design data.
*.kicad_prl

# Backups, autosaves, locks.
*.bak
*-bak
*.kicad_sch-bak
*.kicad_pcb-bak
_autosave-*
\#auto_saved_files\#
*.lck
~*.lck

# Regenerated caches and netlists.
fp-info-cache
*.net

# Fabrication output. Regenerate from the layout. To keep provenance for a
# board that was actually ordered, commit one zipped set per fabricated rev
# instead of the loose files.
*.gbr
*.gbrjob
*.drl
*.ger
gerbers/
production/

# Manufacturer 3D models, large binaries.
*.step
*.stp
*.STEP
*.wrl
